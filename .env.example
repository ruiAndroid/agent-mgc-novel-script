APP_HOST=0.0.0.0
APP_PORT=8110
APP_ENV_FILE=.env.production
AGENT_ID=mgc-novel-to-script
WORKFLOW_ID=novel-to-script-pipeline
SKILLS_DIR=./skills
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_MAX_TOKENS=2048
REQUEST_TIMEOUT_SECONDS=120
LLM_SERVICE_BASE_URL=
# Optional alias for explicit LLM gateway/proxy URL.
ZEROCLAW_LLM_PROXY_BASE_URL=
LLM_SERVICE_API_STYLE=auto
LLM_SERVICE_AUTH_TOKEN=
LLM_SERVICE_AUTH_SCHEME=Bearer
